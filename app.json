{
  "expo": {
    "name": "GenoMatch",
    "slug": "genomatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "GenoMatch is the world's first genotype-aware dating app. Find compatible partners based on AA, AS, SS, AC genotype matching.",
    "primaryColor": "#0D2818",
    "fonts": [
      "./assets/fonts/ClashDisplay-Semibold.otf",
      "./assets/fonts/ClashDisplay-Medium.otf",
      "./assets/fonts/ClashDisplay-Regular.otf",
      "./assets/fonts/Satoshi-Regular.otf",
      "./assets/fonts/Satoshi-Medium.otf",
      "./assets/fonts/Satoshi-Bold.otf"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2818"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ng.genomatch.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "GenoMatch needs access to your photos so you can upload a profile picture."
      }
    },
    "android": {
      "package": "ng.genomatch.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2818"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "oxbreed",
    "extra": {
      "eas": {
        "projectId": "11f7d939-f2b9-4c0c-a1bf-bd7411c45ec6"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "GenoMatch needs access to your photos so you can upload a profile picture."
        }
      ],
      "expo-secure-store",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0D2818"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/ClashDisplay-Semibold.otf",
            "./assets/fonts/ClashDisplay-Medium.otf",
            "./assets/fonts/ClashDisplay-Regular.otf",
            "./assets/fonts/Satoshi-Regular.otf",
            "./assets/fonts/Satoshi-Medium.otf",
            "./assets/fonts/Satoshi-Bold.otf"
          ]
        }
      ]
    ]
  }
}
